generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NivelAcesso {
  OPERADOR
  GESTOR
  ADMIN
}

enum Enquadramento {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
  CEI
  DOMESTICA
  PRODUTOR_RURAL
  PESSOA_FISICA
}

enum AnexoSimples {
  ANEXO_I
  ANEXO_II
  ANEXO_III
  ANEXO_IV
  ANEXO_V
}

enum TipoDocumento {
  CNPJ
  CPF
  CEI
  CNO
}

enum TipoEmpresa {
  COMERCIO
  INDUSTRIA
  SERVICOS
  ADVOCACIA
  CLINICA
  HOLDING
  CONSTRUCAO_CIVIL
  RURAL
  DOMESTICO
  TRANSPORTES
  OUTROS
}

enum NivelComplexidade {
  N1
  N2
  N3
  N4
  N5
}

enum StatusMensal {
  NAO_INICIADO
  PARCIAL
  FINALIZADO
}

enum TipoTarefa {
  RECORRENTE
  PONTUAL
}

model Usuario {
  id         String          @id @default(cuid())
  nome       String
  email      String          @unique
  senha      String
  nivel      NivelAcesso     @defaul
